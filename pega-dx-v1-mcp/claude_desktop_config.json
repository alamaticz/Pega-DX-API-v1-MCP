{
  "mcpServers": {
    "pega-dx-v1": {
      "command": "node",
      "args": ["C:/path/to/pega-dx-v1-mcp/dist/index.js"],
      "env": {
        "PEGA_BASE_URL": "https://your-pega-server.pegacloud.net/prweb",
        "PEGA_USERNAME": "your-operator-id",
        "PEGA_PASSWORD": "your-password"
      }
    }
  }
}
